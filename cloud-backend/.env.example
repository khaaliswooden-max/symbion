# Symbion Cloud Backend Environment Configuration

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/symbion
MONGODB_TEST_URI=mongodb://localhost:27017/symbion_test

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
